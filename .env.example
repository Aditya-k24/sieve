SIEVE_MODE=auto
SIEVE_OLLAMA_BASE_URL=http://localhost:11434
SIEVE_OLLAMA_MODEL=qwen2.5-coder:7b
SIEVE_MAX_CONTEXT_CHARS=20000
SIEVE_DEBUG=0

# Triage: how SIEVE_MODE=auto decides local vs claude.
#   heuristic (default) — deterministic keyword rules, no network call
#   llm                 — asks the local Ollama model to decide instead,
#                          falling back to heuristic on any failure
SIEVE_TRIAGE_METHOD=heuristic
# Only used when SIEVE_TRIAGE_METHOD=llm. Defaults to SIEVE_OLLAMA_MODEL if unset.
SIEVE_TRIAGE_MODEL=
